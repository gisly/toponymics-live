{
  "version": 8,
  "name": "Toponymics Live — Vasilevich palette (PMTiles)",
  "metadata": {
    "description": "MapLibre style based on the custom Mapnik palette from toponymics-live.net. Forest-green land, blue water, pink borders. Designed for the Toponymics Live project on indigenous Siberian toponymy.",
    "based_on": "Local PMTiles file built from OSM Asian Russia (planetiler + openmaptiles)",
    "palette_source": "/home/topo/src/openstreetmap-carto/mapnik.xml on toponymics-live.net VPS"
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "pmtiles:///pmtiles-local/russia-asian.pmtiles",
      "attribution": "© <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> contributors"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#d6e7c8" }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#8cb381",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.15, 8, 0.35, 12, 0.55, 16, 0.85
        ]
      }
    },
    {
      "id": "landcover-scrub",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["in", "class", "scrub", "grass"],
      "paint": {
        "fill-color": "#a5cfa1",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.10, 8, 0.20, 12, 0.35, 16, 0.55
        ]
      }
    },
    {
      "id": "landuse-farmland",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["in", "class", "farmland", "agriculture"],
      "paint": {
        "fill-color": "#e9fed2",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.3, 10, 0.6, 14, 0.9
        ]
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#f5f5dc",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.10, 10, 0.35, 14, 0.6
        ]
      }
    },
    {
      "id": "landuse-cemetery",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "cemetery"],
      "paint": { "fill-color": "#cadaba", "fill-opacity": 0.7 }
    },
    {
      "id": "landuse-industrial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["in", "class", "industrial", "commercial"],
      "paint": { "fill-color": "#e9e9e9", "fill-opacity": 0.5 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#badd69", "fill-opacity": 0.4 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#aad3df" }
    },
    {
      "id": "waterway-river",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["==", "class", "river"],
      "paint": {
        "line-color": "#aad3df",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.5, 8, 1.0, 11, 1.8, 14, 3.0, 17, 5.0
        ]
      }
    },
    {
      "id": "waterway-stream",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["in", "class", "stream", "canal", "ditch"],
      "minzoom": 11,
      "paint": {
        "line-color": "#aad3df",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          11, 0.5, 14, 1.0, 17, 2.0
        ]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#f5f5dc",
        "fill-opacity": 0.8,
        "fill-outline-color": "#d4cfa8"
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "residential", "track"],
      "minzoom": 12,
      "paint": {
        "line-color": "#000000",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          12, 0.5, 16, 2.5
        ]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "residential"],
      "minzoom": 13,
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          13, 0.3, 16, 4
        ]
      }
    },
    {
      "id": "road-secondary-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "paint": {
        "line-color": "#000000",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          8, 0.4, 12, 1.8, 16, 6
        ]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "minzoom": 9,
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          9, 0.3, 12, 1.0, 16, 5
        ]
      }
    },
    {
      "id": "road-primary-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk", "motorway"],
      "paint": {
        "line-color": "#000000",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.4, 10, 2.0, 14, 5, 17, 12
        ]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk", "motorway"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.2, 10, 1.4, 14, 3.5, 17, 10
        ]
      }
    },
    {
      "id": "railway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "rail"],
      "paint": {
        "line-color": "#9aa199",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          8, 0.5, 12, 1.0, 16, 2.0
        ]
      }
    },
    {
      "id": "admin-country",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 2],
      "paint": {
        "line-color": "#ffc0cb",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.6, 6, 1.6, 12, 3.0
        ],
        "line-dasharray": [3, 1]
      }
    },
    {
      "id": "admin-state",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "paint": {
        "line-color": "#ffc0cb",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.3, 8, 1.0, 14, 2.0
        ],
        "line-dasharray": [2, 2],
        "line-opacity": 0.7
      }
    },
    {
      "id": "water-label-river",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["==", "class", "river"],
      "minzoom": 9,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          9, 10, 14, 13
        ],
        "text-letter-spacing": 0.1
      },
      "paint": {
        "text-color": "#6699cc",
        "text-halo-color": "rgba(255, 255, 255, 0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "water-label-area",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "minzoom": 6,
      "layout": {
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          6, 10, 12, 14
        ],
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#6699cc",
        "text-halo-color": "rgba(255, 255, 255, 0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "village", "hamlet"],
      "minzoom": 9,
      "layout": {
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          9, 9, 14, 12
        ],
        "text-anchor": "top",
        "text-offset": [0, 0.5]
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "rgba(255, 255, 255, 0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "town"],
      "minzoom": 5,
      "layout": {
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          5, 10, 12, 16
        ],
        "text-anchor": "top",
        "text-offset": [0, 0.6]
      },
      "paint": {
        "text-color": "#222222",
        "text-halo-color": "rgba(255, 255, 255, 0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "city", "state_capital", "national_capital"],
      "minzoom": 3,
      "layout": {
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          3, 11, 8, 16, 14, 22
        ],
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#222222",
        "text-halo-color": "rgba(255, 255, 255, 0.9)",
        "text-halo-width": 2.0
      }
    },
    {
      "id": "country-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "maxzoom": 6,
      "layout": {
        "text-field": ["coalesce", ["get", "name:ru"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          2, 11, 5, 18
        ],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.2
      },
      "paint": {
        "text-color": "#999999",
        "text-halo-color": "rgba(170, 203, 217, 0.8)",
        "text-halo-width": 1.5
      }
    }
  ]
}
