# Django
DJANGO_SECRET_KEY=change-me-in-production-please-make-it-long-and-random
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django,new.toponymics-live.net,toponymics-live.net
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8000,https://new.toponymics-live.net

# Postgres
POSTGRES_DB=toponymics
POSTGRES_USER=toponymics
POSTGRES_PASSWORD=change-me-locally-is-fine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
VITE_PMTILES_URL=/pmtiles/siberia.pmtiles
VITE_MAP_STYLE_URL=/map-style/style.json

# Media (locally just a folder, in prod points to VPS volume)
MEDIA_ROOT=/app/media
